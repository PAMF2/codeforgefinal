{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Assembly-SWE Task",
  "type": "object",
  "required": [
    "task_id",
    "tier",
    "instruction"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "tier": {
      "type": "integer",
      "minimum": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "expected_stdout": {
      "type": "string"
    },
    "expected_exit_code": {
      "type": "integer"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
